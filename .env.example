# Copy to .env and fill in. Used by `docker compose --env-file .env up`.

# Phoenix secret. Generate with: mix phx.gen.secret
SECRET_KEY_BASE=replace-me-with-64-chars

# Public host (must point at this server via DNS A/AAAA record).
PHX_HOST=chirp.example.com

# ntfy topic — treat as a password. Long, random.
NTFY_TOPIC=noisy-chirp-replace-me-with-a-long-random-string

# Default is the public ntfy.sh; override for self-hosted ntfy.
NTFY_BASE_URL=https://ntfy.sh

# Admin password — protects /admin. Pick something long.
ADMIN_PASSWORD=replace-me-with-a-long-password

# AI text generator for notifications. Options: anthropic | ollama | none
# - anthropic: cloud, fast, best quality (needs ANTHROPIC_API_KEY)
# - ollama:    local model via Ollama (needs OLLAMA_BASE_URL reachable)
# - none:      no AI, always use bird-themed fallback templates
CHIRP_WRITER=anthropic

# Anthropic (only when CHIRP_WRITER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Ollama (only when CHIRP_WRITER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b
